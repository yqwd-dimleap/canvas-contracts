{
  "name": "@yqwd-dimleap/canvas-contracts",
  "version": "1.0.2",
  "description": "Shared TypeScript and Zod contracts for Dimleap canvas services.",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./billing": {
      "types": "./dist/billing/index.d.ts",
      "import": "./dist/billing/index.js"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "import": "./dist/canvas/index.js"
    },
    "./generation": {
      "types": "./dist/generation/index.d.ts",
      "import": "./dist/generation/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.js"
    },
    "./rag": {
      "types": "./dist/rag/index.d.ts",
      "import": "./dist/rag/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun run build",
    "pack:verify": "npm pack --json --silent --pack-destination /tmp > /tmp/canvas-contracts-pack.json && node scripts/verify-package.mjs $(node -p \"const data=JSON.parse(require('fs').readFileSync('/tmp/canvas-contracts-pack.json','utf8')); const path=require('path'); console.log(path.isAbsolute(data[0].filename) ? data[0].filename : path.join('/tmp', data[0].filename))\")",
    "prepack": "bun run build",
    "prepare": "husky"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yqwd-dimleap/canvas-contracts.git"
  },
  "author": "Deep CX",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/deep-cx/canvas-contracts/issues"
  },
  "homepage": "https://github.com/deep-cx/canvas-contracts#readme"
}
