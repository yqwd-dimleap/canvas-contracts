{
  // 使用 Biome 作为默认格式化工具
  "editor.defaultFormatter": "biomejs.biome",

  // 保存时自动格式化
  "editor.formatOnSave": true,

  // 保存时自动修复（包括 lint 问题）
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit"
  },

  // TypeScript/JavaScript 文件使用 Biome
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  }
}
